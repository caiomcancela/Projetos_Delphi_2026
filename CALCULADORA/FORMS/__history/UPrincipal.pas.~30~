{$Region 'Operaçãos com JSON'}
// Se estiver com um arquivo criado e estiver com o visor vazio, traz a
// informação do arquivo JSON, Se não, Cria o arquivo e o salva.
procedure TForm_Principal.Btn_SalvarClick(Sender: TObject);
var JSONobj : TJSONObject;
Conteudo : String;
Caminho : String;
begin
  Caminho := TPath.Combine(ExtractFilePath(Application.ExeName),'numero.json');
  JSONobj := TJSONObject.Create;

 if (Tfile.Exists(Caminho)) and (Form_Principal.Visor.Caption ='') then
 begin
    Conteudo := TFile.ReadAllText(Caminho, TEncoding.UTF8);
    JSONobj := TJSONObject.ParseJSONValue(Conteudo) as TJSONObject;
    Form_Principal.Visor.Caption := JSONobj.GetValue<String>('Numero Salvo')
 end
 else
 begin
  JSONobj.AddPair('Numero Salvo',Form_Principal.Visor.Caption);


  TFile.WriteAllText(Caminho,JSONobj.ToJSON,TEncoding.UTF8);
 end;
 JSONobj.FreeInstance;

end;
// Deleta o arquivo .json, da pasta executavel.
procedure TForm_Principal.Btn_RemoverClick(Sender: TObject);
Var Caminho : String;
begin
Caminho := TPath.Combine(ExtractFilePath(Application.ExeName),'numero.json');
TFile.Delete(Caminho);

end;

{$endregion}


{$Region 'Outros'}
//Verifica se o primeiro numero esta salvo no primeiro campo do array,se estiver
//ele ira salvar no segundo.
procedure TForm_Principal.verificarArray(valor: Integer);
begin
  if Form_Principal.Visor.Caption = '' then
  begin
    exit
  end;

  if Numeros[0] = -1 then
  begin
    Numeros[0] := valor;
  end
  else
  begin
     Numeros[1] := valor;
  end;
end;

//Procedure chamada pelas procedures de Operações para estar fazendo o calculo.
procedure TForm_Principal.RealizarOperação;
begin
   if (Operacao = 1) and (Numeros[0] <> 0) then
    begin
      resultado:= numeros[0] div numeros[1];
    end
    else if (Operacao =2) then
    begin
      resultado:= numeros[0] * numeros[1];
    end
    else if(Operacao =3) then
    begin
      resultado:= numeros[0] - numeros[1];
    end
    else if(Operacao =4)  then
    begin
      resultado:= numeros[0] + numeros[1];
    end
    else
    begin
       ShowMessage('Ocorreu algum erro, tente novamente');
       exit;
    end;
    Numeros[0] := resultado;
end;

// Exclui as informações salvas em numeros e a que esta no visor.
procedure TForm_Principal.Btn_ApagarClick(Sender: TObject);
begin
  Form_Principal.Visor.Caption := '';
  Numeros[0] := -1;
  Numeros[1] := -1;
  operacao := 0;
end;

//Implementa o igual trazendo o resultado da operação.
procedure TForm_Principal.Btn_IgualClick(Sender: TObject);
begin
    verificarArray(StrToInt(Form_Principal.Visor.Caption));
    RealizarOperação;
    Form_Principal.Visor.Caption := IntToStr(resultado);
    Operacao := 0;
end;

//Caso o numero do visor esteja negativo, ele o trasforma em positivo, caso
//contrario trasforma em positivo
procedure TForm_Principal.Btn_NegativoClick(Sender: TObject);
var display: Integer;
begin
  if (Form_Principal.Visor.Caption <> '') then
  begin
      display := StrtoInt(Form_Principal.Visor.Caption);
      if (display >= 0) then
      begin
         Form_Principal.Visor.Caption := '-' + InttoStr(display);
      end
      else
      begin
        Form_Principal.Visor.Caption := InttoStr(abs(display));
      end;
  end;

end;
{$endregion}

