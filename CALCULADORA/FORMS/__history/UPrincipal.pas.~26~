unit UPrincipal;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.Buttons, Vcl.ExtCtrls,System.JSON,System.IOUtils;

type
  TForm_Principal = class(TForm)
    Btn3: TBitBtn;
    Btn2: TBitBtn;
    Btn1: TBitBtn;
    Btn_Divisao: TBitBtn;
    Btn6: TBitBtn;
    Btn9: TBitBtn;
    Btn_Virgula: TBitBtn;
    Btn_Salvar: TBitBtn;
    Btn5: TBitBtn;
    Btn_Subtração: TBitBtn;
    Btn0: TBitBtn;
    Btn_Excluir: TBitBtn;
    Btn4: TBitBtn;
    Btn7: TBitBtn;
    Btn_Negativo: TBitBtn;
    Btn_Apagar: TBitBtn;
    Btn_Multiplicacao: TBitBtn;
    Btn8: TBitBtn;
    Btn_Soma: TBitBtn;
    Btn_Igual: TBitBtn;
    Visor: TPanel;
    procedure Btn1Click(Sender: TObject);
    procedure Btn2Click(Sender: TObject);
    procedure Btn3Click(Sender: TObject);
    procedure Btn4Click(Sender: TObject);
    procedure Btn5Click(Sender: TObject);
    procedure Btn6Click(Sender: TObject);
    procedure Btn7Click(Sender: TObject);
    procedure Btn8Click(Sender: TObject);
    procedure Btn9Click(Sender: TObject);
    procedure Btn0Click(Sender: TObject);
    procedure Btn_ApagarClick(Sender: TObject);
    procedure Btn_DivisaoClick(Sender: TObject);
    procedure verificarArray(valor: Integer);
    procedure Btn_MultiplicacaoClick(Sender: TObject);
    procedure Btn_SubtraçãoClick(Sender: TObject);
    procedure Btn_SomaClick(Sender: TObject);
    procedure Btn_IgualClick(Sender: TObject);
    procedure Btn_NegativoClick(Sender: TObject);
    procedure Btn_SalvarClick(Sender: TObject);
    procedure Btn_ExcluirClick(Sender: TObject);
    procedure RealizarOperação;
    private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form_Principal: TForm_Principal;
  Numeros: array[0..1] of Integer = (-1,-1);
  operacao: Integer = 0;
  resultado: Integer = 0;

implementation
{$R *.dfm}

{$Region 'Botões Valores'}

//Adiciona no visor o numero 0.
procedure TForm_Principal.Btn0Click(Sender: TObject);
begin
  Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '0';
end;

//Adiciona no visor o numero 1.
procedure TForm_Principal.Btn1Click(Sender: TObject);
begin
  Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '1';
end;

//Adiciona no visor o numero 2.
procedure TForm_Principal.Btn2Click(Sender: TObject);
begin
   Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '2';
end;

//Adiciona no visor o numero 3.
procedure TForm_Principal.Btn3Click(Sender: TObject);
begin
   Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '3';
end;

//Adiciona no visor o numero 4.
procedure TForm_Principal.Btn4Click(Sender: TObject);
begin
Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '4';
end;

//Adiciona no visor o numero 5.
procedure TForm_Principal.Btn5Click(Sender: TObject);
begin
Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '5';
end;

//Adiciona no visor o numero 6.
procedure TForm_Principal.Btn6Click(Sender: TObject);
begin
Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '6';
end;

//Adiciona no visor o numero 7.
procedure TForm_Principal.Btn7Click(Sender: TObject);
begin
Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '7';
end;

//Adiciona no visor o numero 8.
procedure TForm_Principal.Btn8Click(Sender: TObject);
begin
Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '8'
end;

//Adiciona no visor o numero 9.
procedure TForm_Principal.Btn9Click(Sender: TObject);
begin
  Form_Principal.Visor.Caption := Form_Principal.Visor.Caption + '9';
end;

{$endregion}


procedure TForm_Principal.Btn_ApagarClick(Sender: TObject);
begin
  Form_Principal.Visor.Caption := '';
  Numeros[0] := -1;
  Numeros[1] := -1;
end;


procedure TForm_Principal.Btn_DivisaoClick(Sender: TObject);
begin
  Operacao := 1;
  verificarArray(StrToInt(Form_Principal.Visor.Caption));
  Form_Principal.Visor.Caption := '';

end;


procedure TForm_Principal.Btn_ExcluirClick(Sender: TObject);
Var Caminho : String;
begin
Caminho := TPath.Combine(ExtractFilePath(Application.ExeName),'numero.json');
TFile.Delete(Caminho);

end;

procedure TForm_Principal.Btn_IgualClick(Sender: TObject);
begin
    verificarArray(StrToInt(Form_Principal.Visor.Caption));

    RealizarOperação;
    Form_Principal.Visor.Caption := IntToStr(resultado);
    Form_Principal.Btn_Igual.Enabled := false;
end;

procedure TForm_Principal.Btn_MultiplicacaoClick(Sender: TObject);
begin
    Operacao := 2;
    verificarArray(StrToInt(Form_Principal.Visor.Caption));
    Form_Principal.Visor.Caption := '';
end;

procedure TForm_Principal.Btn_NegativoClick(Sender: TObject);
var display: Integer;
begin
  if (Form_Principal.Visor.Caption <> '') then
  begin
      display := StrtoInt(Form_Principal.Visor.Caption);
      if (display >= 0) then
      begin
         Form_Principal.Visor.Caption := '-' + InttoStr(display);
      end
      else
      begin
        Form_Principal.Visor.Caption := InttoStr(abs(display));
      end;
  end;

end;

procedure TForm_Principal.Btn_SalvarClick(Sender: TObject);
var JSONobj : TJSONObject;
Conteudo : String;
Caminho : String;
begin
  Caminho := TPath.Combine(ExtractFilePath(Application.ExeName),'numero.json');
  JSONobj := TJSONObject.Create;

 if (Tfile.Exists(Caminho)) and (Form_Principal.Visor.Caption ='') then
 begin
    Conteudo := TFile.ReadAllText(Caminho, TEncoding.UTF8);
    JSONobj := TJSONObject.ParseJSONValue(Conteudo) as TJSONObject;
    Form_Principal.Visor.Caption := JSONobj.GetValue<String>('Numero Salvo')
 end
 else
 begin
  JSONobj.AddPair('Numero Salvo',Form_Principal.Visor.Caption);


  TFile.WriteAllText(Caminho,JSONobj.ToJSON,TEncoding.UTF8);
 end;
 JSONobj.FreeInstance;

end;

procedure TForm_Principal.Btn_SomaClick(Sender: TObject);
begin
  Operacao := 4;
  verificarArray(StrToInt(Form_Principal.Visor.Caption));
  Form_Principal.Visor.Caption := '';
end;

procedure TForm_Principal.Btn_SubtraçãoClick(Sender: TObject);
begin
  Operacao := 3;
  verificarArray(StrToInt(Form_Principal.Visor.Caption));
  Form_Principal.Visor.Caption := '';
end;

procedure TForm_Principal.verificarArray(valor: Integer);
begin
   if Numeros[0] = -1 then
  begin
    Numeros[0] := valor;
  end
  else
  begin
     Numeros[1] := valor;
  end;
end;

procedure TForm_Principal.RealizarOperação;
begin
   if (Operacao = 1) and (Numeros[1] <> 0) then
    begin
      resultado:= numeros[0] div numeros[1];
    end
    else if (Operacao =2) then
    begin
      resultado:= numeros[0] * numeros[1];
    end
    else if(Operacao =3) then
    begin
      resultado:= numeros[0] - numeros[1];
    end
    else if(Operacao =4)  then
    begin
      resultado:= numeros[0] + numeros[1];
    end
    else
    begin
       ShowMessage('Ocorreu algum erro, tente novamente');
       exit;
    end;
end;
end.
