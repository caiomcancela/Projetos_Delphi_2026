unit FormLogin;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, cxGraphics, cxControls, cxLookAndFeels,
  cxLookAndFeelPainters, cxContainer, cxEdit, cxLabel, cxTextEdit, Vcl.Menus,
  Vcl.StdCtrls, cxButtons;

type
  TForm_Login = class(TForm)
    Imp_Usuario: TcxTextEdit;
    Lbl_Usuario: TcxLabel;
    Imp_Senha: TcxTextEdit;
    Lbl_Senha: TcxLabel;
    Btn_Entrar: TcxButton;
    procedure Btn_EntrarClick(Sender: TObject);
    procedure Imp_UsuarioKeyPress(Sender: TObject; var Key: Char);
    procedure Imp_SenhaKeyPress(Sender: TObject; var Key: Char);
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form_Login: TForm_Login;

implementation

{$R *.dfm}

uses FormPrincipal;

procedure TForm_Login.Btn_EntrarClick(Sender: TObject);
begin
  if(Form_Login.Imp_Usuario.Text = 'SIMPLESOFT') and (Form_Login.Imp_Senha.Text = '123456789')then
  begin
     Try
       Application.CreateForm(TForm_Principal,Form_Principal);
       Form_Principal.showmodal;
     Finally
       FreeAndNil(Form_Principal);
     End;
  end
  else
  begin
    ShowMessage('Usuario ou Senha Incorreta');
  end;
end;

procedure TForm_Login.Imp_SenhaKeyPress(Sender: TObject; var Key: Char);
begin
   if key = #13 then
    Form_Login.Btn_Entrar.Click;
end;

procedure TForm_Login.Imp_UsuarioKeyPress(Sender: TObject; var Key: Char);
begin
  if key = #13 then
    Form_Login.Imp_Senha.SetFocus;
end;



end.
